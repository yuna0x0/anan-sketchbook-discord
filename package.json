{
  "name": "anan-sketchbook-discord",
  "version": "1.0.0",
  "description": "A Discord bot for Manosaba (Magical Girl Witch Trials) that generates sketchbook images and in-game style dialogue images",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "register": "tsx src/register.ts",
    "migrate": "tsx src/migrate-cli.ts",
    "migrate:status": "tsx src/migrate-cli.ts status",
    "migrate:rollback": "tsx src/migrate-cli.ts rollback",
    "test": "node --import tsx --test --test-concurrency=1 test/**/*.test.ts",
    "test:utils": "node --import tsx --test test/utils/*.test.ts",
    "test:config": "node --import tsx --test test/config/*.test.ts",
    "test:database": "node --import tsx --test --test-concurrency=1 test/database/*.test.ts",
    "test:services": "node --import tsx --test --test-concurrency=1 test/services/*.test.ts"
  },
  "keywords": [
    "discord",
    "bot",
    "manosaba",
    "magical-girl-witch-trials",
    "natsume-anan",
    "sketchbook",
    "dialogue",
    "image-generator"
  ],
  "author": "yuna0x0 <yuna@yuna0x0.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/yuna0x0/anan-sketchbook-discord.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "dependencies": {
    "@discordjs/rest": "^2.6.1",
    "@twemoji/api": "^17.0.2",
    "canvas": "^3.2.2",
    "discord-api-types": "^0.38.42",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
